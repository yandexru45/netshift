# Padkap Evolution — .dockerignore for Docker builds
# Speed up build context by excluding unnecessary files

# Dependencies
node_modules/
fe-app-padkap/node_modules/
fe-app-padkap/.yarn/

# Build artifacts
fe-app-padkap/dist/
*.ipk
*.apk

# Git
.git/
.gitattributes
.gitignore
.github/

# Documentation
*.md
!README.md
agent/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Tests (excluded from build, mounted separately)
tests/test-results/
