{
  "luci-app-netshift": {
    "description": "Grant UCI and RPC access to LuCI app NetShift",
    "read": {
      "file": {
        "/etc/init.d/netshift": [
          "exec"
        ],
        "/usr/bin/netshift": [
          "exec"
        ]
      },
      "ubus": {
        "service": [
          "list"
        ]
      },
      "uci": [
        "netshift"
      ]
    },
    "write": {
      "uci": [
        "netshift"
      ]
    }
  }
}
